         <component>
            <section ID="id_link_3b2c7e71-d1fa-fc91-e063-6294a90a8701">
               <id root="3b2c7e71-d1f9-fc91-e063-6294a90a8701"/>
               <code code="34067-9" codeSystem="2.16.840.1.113883.6.1" displayName="INDICATIONS &amp; USAGE SECTION"/>
               <text>
                  <list listType="unordered">
                     <item>cures most athlete's foot (tinea pedis)</item>
                     <item>cures most jock itch (tinea crurs) and ringworm (tinea corporis)</item>
                     <item>relieves itching, burning, cracking and scaling which accompany these conditions</item>
                  </list>
               </text>
               <effectiveTime value="20250818"/>
            </section>
         </component>
         <component>
