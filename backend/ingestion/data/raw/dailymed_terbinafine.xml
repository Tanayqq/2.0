               <id root="3b2c7fe2-5374-f7cc-e063-6294a90aaf7d"/>
               <code code="34071-1" codeSystem="2.16.840.1.113883.6.1" displayName="WARNINGS SECTION"/>
               <text>
                  <paragraph>For external use only</paragraph>
               </text>
               <effectiveTime value="20250818"/>
               <component>
                  <section ID="id_link_3b2c830d-3d54-cbc0-e063-6394a90a5766">
                     <id root="3b2c830d-3d53-cbc0-e063-6394a90a5766"/>
                     <code code="50570-1" codeSystem="2.16.840.1.113883.6.1" displayName="OTC - DO NOT USE SECTION"/>
                     <text>
                        <list listType="unordered">
                           <item>on nails or scalp</item>
                           <item>in or near the mouth or eyes</item>
                           <item>for vaginal yeast infections</item>
                        </list>
                     </text>
                     <effectiveTime value="20250818"/>
                  </section>
               </component>
               <component>
                  <section ID="id_link_3b2c8794-a519-cfac-e063-6394a90a7bbf">
                     <id root="3b2c8794-a518-cfac-e063-6394a90a7bbf"/>
                     <code code="50567-7" codeSystem="2.16.840.1.113883.6.1" displayName="OTC - WHEN USING SECTION"/>
                     <text>
                        <paragraph>do not get into eyes, if eye contact occurs, rinse thoroughly with water.</paragraph>
                     </text>
                     <effectiveTime value="20250818"/>
                  </section>
               </component>
               <component>
                  <section ID="id_link_3b2c8794-a51b-cfac-e063-6394a90a7bbf">
                     <id root="3b2c8794-a51a-cfac-e063-6394a90a7bbf"/>
                     <code code="50566-9" codeSystem="2.16.840.1.113883.6.1" displayName="OTC - STOP USE SECTION"/>
                     <text>
                        <paragraph>stop use and ask a doctor if too much irritation occurs or gets worse.</paragraph>
                     </text>
                     <effectiveTime value="20250818"/>
                  </section>
               </component>
               <component>
                  <section ID="id_link_3b2c8ce8-db3f-0fac-e063-6294a90aed36">
                     <id root="3b2c8ce8-db3e-0fac-e063-6294a90aed36"/>
                     <code code="50565-1" codeSystem="2.16.840.1.113883.6.1" displayName="OTC - KEEP OUT OF REACH OF CHILDREN SECTION"/>
                     <text>
                        <paragraph>if swallowed, call a poison control centre or get medical help right away.</paragraph>
                     </text>
                     <effectiveTime value="20250818"/>
                  </section>
               </component>
            </section>
