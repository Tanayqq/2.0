               <code code="34066-1" codeSystem="2.16.840.1.113883.6.1" displayName="BOXED WARNING SECTION"/>
               <text>
                  <paragraph>WARNING: Accidental overdose of iron-containing products is a leading cause of fatal poisoning in children under 6. Keep this product out of reach of children. In case of accidental overdose, call a doctor or poison control center immediately.</paragraph>
                  <paragraph/>
               </text>
               <effectiveTime value="20130327"/>
            </section>
