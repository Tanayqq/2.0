               <code code="60561-8" codeSystem="2.16.840.1.113883.6.1" displayName="OTHER SAFETY INFORMATION"/>
               <title>Other information </title>
               <text>
                  <list listType="unordered">
                     <item>
                        <caption>•</caption>
                        <content styleCode="bold">each 30 mL contains:</content> sodium 28 mg</item>
                     <item>
                        <caption>•</caption>store at 20-25°C (68-77°F)</item>
                  </list>
               </text>
               <effectiveTime value="20260701"/>
            </section>
         </component>
