               <code code="55106-9" codeSystem="2.16.840.1.113883.6.1" displayName="OTC - ACTIVE INGREDIENT SECTION"/>
               <title>Active ingredients (in each 30 mL) </title>
               <text>
                  <paragraph>Acetaminophen 1000 mg</paragraph>
                  <paragraph>Dextromethorphan HBr 30 mg</paragraph>
                  <paragraph>Doxylamine succinate 12.5 mg</paragraph>
               </text>
               <effectiveTime value="20260213"/>
            </section>
