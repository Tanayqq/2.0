# LLM Provider Configuration
ACTIVE_LLM_PROVIDER=Groq
TARGET_PRODUCTION_MODEL=MedGemma
GROQ_API_KEY=gsk_your_groq_api_key_here

# Vector Database (Qdrant Cloud)
# For local Docker, leave QDRANT_API_KEY blank and set URL to http://localhost:6333
QDRANT_URL=https://your-cluster-url.cloud.qdrant.io
QDRANT_API_KEY=your_qdrant_api_key_here

# Network Configuration
# Specify the exact Vercel domain to enforce strict CORS
FRONTEND_URL=https://medref-clinical.vercel.app

# App Settings
DEBUG=False
APP_VERSION=1.0.0
